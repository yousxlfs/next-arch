  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^20",
    "eslint": "^9.39.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
