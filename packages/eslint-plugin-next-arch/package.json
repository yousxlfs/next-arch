{
  "name": "eslint-plugin-next-arch",
  "version": "0.1.0",
  "description": "ESLint rules for Next Architecture (Feature-Sliced Design)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
