{
  "name": "@yousxlfs/next-arch",
  "version": "0.3.1",
  "description": "CLI for scaffolding Next.js 16 projects with Feature-Sliced Design",
  "author": "yousxlfs",
  "license": "MIT",
  "homepage": "https://github.com/yousxlfs/next-arch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yousxlfs/next-arch.git",
    "directory": "packages/next-arch"
  },
  "bugs": {
    "url": "https://github.com/yousxlfs/next-arch/issues"
  },
  "keywords": [
    "nextjs",
    "next",
    "cli",
    "feature-sliced-design",
    "fsd",
    "architecture",
    "scaffold"
  ],
  "main": "dist/index.js",
  "bin": {
    "next-arch": "dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "vendor"
  ],
  "scripts": {
    "build": "tsup && node scripts/sync-vendor.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "depcheck": "depcheck",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@clack/prompts": "0.10.1",
    "chalk": "5.6.2",
    "commander": "13.1.0",
    "fs-extra": "11.3.5"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.19.43",
    "depcheck": "1.4.7",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}
